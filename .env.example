# Personal Access Token do Figma
# Gere em: https://www.figma.com/settings → Personal access tokens
# Escopos necessários: file_content:read e file_comments:write
FIGMA_TOKEN=seu_token_figma_aqui

# Chave da API Anthropic (Claude) para as etapas de crítica (3) e geração do PRD (5)
# Gere em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# Modelo Claude a usar (opcional, padrão: claude-sonnet-4-5-20250929)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
# Service role key (SECRETA - Supabase Dashboard > Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
# Segredo usado uma única vez para criar o primeiro super-admin via /api/admin/bootstrap
ADMIN_BOOTSTRAP_SECRET=defina_um_segredo_forte

# Worker da análise (continua processando mesmo com a aba do navegador fechada)
# Segredo compartilhado entre a rota interna (/api/internal/analysis/step) e a
# Edge Function do Supabase. Use o MESMO valor nos dois lugares.
ANALYSIS_WORKER_SECRET=defina_um_segredo_forte_para_o_worker
# URL pública da Edge Function que orquestra a análise no backend.
# Sem ela (ex.: dev local), o servidor encadeia os passos no próprio processo.
SUPABASE_FUNCTION_URL=https://SEU_PROJETO.supabase.co/functions/v1/process-analysis-step